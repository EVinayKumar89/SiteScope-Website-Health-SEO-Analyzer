# ============================================================
# SiteScope — Environment Variables
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Replace the placeholder with your real API key
# 3. Never commit .env to GitHub (it's in .gitignore)

# Google PageSpeed Insights API Key (FREE)
# Get yours in 2 minutes:
#   → https://console.cloud.google.com/
#   → Create project → Enable "PageSpeed Insights API"
#   → APIs & Services → Credentials → Create API Key
#   → Restrict key to "PageSpeed Insights API" for security
#
# Free tier: 25,000 requests/day — more than enough
# Without a key: works but limited to ~1 req/2 min per IP

REACT_APP_PAGESPEED_API_KEY=your_google_api_key_here

# App Config (optional)
REACT_APP_NAME=SiteScope
REACT_APP_VERSION=1.0.0
